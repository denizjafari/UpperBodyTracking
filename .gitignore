# ====================================================================
# Combined .gitignore — Unity 6000.4 project + Python (RPi side)
# Based on the canonical github/gitignore Unity template, with project
# additions for the IMU/Python pipeline under src/ and macOS noise.
# ====================================================================

# ---- macOS ----
.DS_Store
._*

# ---- Unity (canonical github/gitignore Unity.gitignore) ----
.utmp/
/[Ll]ibrary/
unity/[Ll]ibrary/
/[Tt]emp/
unity/[Tt]emp/
/[Oo]bj/
unity/[Oo]bj/
/[Bb]uild/
unity/[Bb]uild/
/[Bb]uilds/
unity/[Bb]uilds/
/[Ll]ogs/
unity/[Ll]ogs/
/[Uu]ser[Ss]ettings/
unity/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size and could contain sensitive data
/[Mm]emoryCaptures/
unity/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/
unity/[Rr]ecordings/

# Asset Store tools — uncomment if you don't want them tracked
# unity/[Aa]ssets/AssetStoreTools*

# Jetbrains Rider auto-generated plugin
unity/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio cache
.vs/

# Gradle cache
.gradle/

# Auto-generated VS / MD / Consulo solutions
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity-generated meta for the above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash / sysinfo dumps
sysinfo.txt
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Quest / Unity 6000.4 build sidecars (auto-generated, very large)
*_BurstDebugInformation_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/

# Crashlytics
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables defaults
/ServerData
unity/[Aa]ssets/StreamingAssets/aa*
unity/[Aa]ssets/AddressableAssetsData/link.xml*
unity/[Aa]ssets/Addressables_Temp*
unity/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated
unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated test scenes
unity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# IDE folders
.idea/
.vscode/

# ---- Python (existing src/opensense_rt) ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ---- Local environment ----
*.local
.env
